# ============================================================
# Motamot — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ---- Supabase ----
# Get these from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # keep secret — server only

# ---- App ----
NEXT_PUBLIC_BASE_URL=http://localhost:3000         # production: https://motamot.vercel.app

# ---- Google Translate (optional) ----
# Create a key at: https://console.cloud.google.com → APIs → Cloud Translation
GOOGLE_TRANSLATE_API_KEY=

# ---- Google AdSense (optional) ----
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT=XXXXXXXXXX

# ---- Profanity blacklists (optional, comma-separated) ----
# English custom words to add to the default filter
CUSTOM_BLACKLIST=

# Bangla vulgar words (comma-separated, no spaces around commas)
BANGLA_BLACKLIST=

# ---- Analytics (optional) ----
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ---- Error monitoring (optional) ----
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
